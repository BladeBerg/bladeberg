{
    "name": "bladeberg/bladeberg",
    "description": "Gutenberg inside Laravel — bring the WordPress block editor to your Laravel application.",
    "type": "library",
    "keywords": ["laravel", "gutenberg", "block-editor", "cms", "wordpress", "bladeberg"],
    "homepage": "https://github.com/BladeBerg/bladeberg",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "BladeBerg",
            "email": "hello@bladeberg.dev",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/BladeBerg/bladeberg/issues",
        "source": "https://github.com/BladeBerg/bladeberg"
    },
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "orchestra/testbench": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "Bladeberg\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Bladeberg\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Bladeberg\\BladebergServiceProvider"
            ],
            "aliases": {
                "Bladeberg": "Bladeberg\\Facades\\Bladeberg"
            }
        }
    },
    "suggest": {
        "spatie/laravel-medialibrary": "Required for the Spatie media driver (automatic thumbnails, conversions, multi-disk). Set media.driver = 'spatie' in config/bladeberg.php."
    },
    "scripts": {
        "test": "phpunit"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
