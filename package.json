{
  "name": "@bladeberg/editor",
  "version": "0.2.7",
  "description": "Headless BladeBerg block editor — the Gutenberg editor for SPA/mobile frontends talking to a Laravel backend.",
  "license": "GPL-2.0-or-later",
  "type": "module",
  "homepage": "https://github.com/BladeBerg/bladeberg",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BladeBerg/bladeberg.git"
  },
  "bugs": {
    "url": "https://github.com/BladeBerg/bladeberg/issues"
  },
  "keywords": [
    "gutenberg",
    "block-editor",
    "wordpress",
    "laravel",
    "bladeberg",
    "headless",
    "react"
  ],
  "main": "dist-npm/bladeberg.js",
  "module": "dist-npm/bladeberg.js",
  "exports": {
    ".": {
      "import": "./dist-npm/bladeberg.js"
    },
    "./style.css": "./dist-npm/style.css"
  },
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist-npm",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:npm": "vite build --config vite.npm.config.js",
    "prepublishOnly": "vite build --config vite.npm.config.js"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@automattic/isolated-block-editor": "2.30.0",
    "@vitejs/plugin-react": "^4.2.0",
    "sass": "^1.83.4",
    "sass-embedded": "^1.83.4",
    "vite": "^5.0.0"
  },
  "overrides": {
    "@wordpress/sync": "1.35.0"
  }
}
